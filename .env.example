# Supabase
SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_ANON_KEY=your_supabase_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key
SUPABASE_BUCKET=your_supabase_bucket

# Nuxt public runtime config
# 目前專案前端主要讀 SUPABASE_URL / SUPABASE_ANON_KEY，
# 但若部署平台偏好 NUXT_PUBLIC_* 命名，可一併補上相同值。
NUXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co
NUXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=your_supabase_anon_key

# Netlify Blobs / server routes
NETLIFY_SITE_ID=your_netlify_site_id
NETLIFY_AUTH_TOKEN=your_netlify_personal_access_token

# Web Push (VAPID)
# 執行 `npx web-push generate-vapid-keys` 產生
VAPID_EMAIL=mailto:admin@yourdomain.com
NUXT_PUBLIC_VAPID_PUBLIC_KEY=your_vapid_public_key
VAPID_PRIVATE_KEY=your_vapid_private_key
